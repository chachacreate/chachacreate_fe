# 빌드 스테이지
# React 빌드에 필요한 Node.js 런타임 이미지 사용, builder 별칭 부여
FROM node:18-alpine AS builder

# 컨테이너 내 작업 디렉토리를 /app으로 설정
WORKDIR /app

# package.json 설정 파일들 먼저 복사 (레이어 캐싱 최적화)
COPY package*.json ./

# 의존성 다운로드 (별도 레이어로 캐시)
RUN npm i --force
# 소스코드 복사
COPY . .
# 빌드 실행
RUN npm run build-prod

# Nginx 스테이지
# 빌드 도구 없는 경량 런타임 nginx 사용
FROM nginx:alpine

# 빌드된 React 앱을 nginx로 복사 (정적 파일 복사)
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80 443

CMD ["nginx", "-g", "daemon off;"]